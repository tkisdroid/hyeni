VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_KAKAO_APP_KEY=
# KAKAO_REST_KEY moved to Supabase Edge Function secret. Set with:
#   npx supabase secrets set KAKAO_REST_KEY=<rest-api-key>
# (Do NOT add as a VITE_ var — that would ship it in the client bundle.)
# Phase G-2: Naver 소셜 로그인. developers.naver.com 에서 애플리케이션 등록 후
# Client ID 를 입력. Client Secret 은 Supabase Edge Function secrets 에만 등록.
# Edge Function secrets: NAVER_CLIENT_ID, NAVER_CLIENT_SECRET
VITE_NAVER_CLIENT_ID=

# Qonversion + Google Play Billing
VITE_QONVERSION_PROJECT_KEY=
VITE_QONVERSION_ENVIRONMENT=sandbox
VITE_QONVERSION_ENTITLEMENT_ID=premium
VITE_QONVERSION_KIDS_MODE=true
VITE_QONVERSION_PROXY_URL=
