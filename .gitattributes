# 라인엔딩 정책 — 텍스트 파일은 LF 강제
# softBrandVisualSystem / realServicesHardening 테스트가 \n 정확 매칭을 검증하므로
# Windows 환경의 core.autocrlf=true 가 CRLF 로 되돌리는 것을 차단해야 한다.
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지 (cmd/PowerShell 호환)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 바이너리 — EOL 변환 금지
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.apk   binary
*.aab   binary
*.keystore binary
*.jks   binary
*.pdf   binary
